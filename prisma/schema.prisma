generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Novel {
  id            String   @id @default(uuid())
  title         String
  titleZh       String?  @map("title_zh")
  descriptionZh String?  @map("description_zh")
  platform      String
  tags          String
  rankingTime   String   @map("ranking_time")
  score         Float
  url           String   @unique
  cover         String?
  description   String?
  views         Int?
  totalChapters Int?     @map("total_chapters")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([platform])
  @@index([rankingTime])
  @@index([score])
  @@map("novels")
}

model Drama {
  id            String   @id @default(uuid())
  title         String
  platform      String
  tags          String
  chartType     String   @map("chart_type")
  score         Float
  url           String   @unique
  cover         String?
  description   String?
  titleZh       String?  @map("title_zh")
  descriptionZh String?  @map("description_zh")
  views         Int?
  totalEpisodes Int?     @map("total_episodes")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([platform])
  @@index([chartType])
  @@index([score])
  @@map("dramas")
}

model SyncLog {
  id         String   @id @default(uuid())
  category   String
  platform   String
  count      Int
  status     String
  errorMsg   String?  @map("error_msg")
  finishedAt DateTime @map("finished_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([createdAt])
  @@map("sync_logs")
}
